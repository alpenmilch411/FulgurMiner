# BrowserCoin miner configuration.
#
# Easiest path: just run `npm start` — it asks for your wallet, lets you pick a
# pool, and writes .env.local for you. Prefer to configure by hand? Copy this
# file to `.env.local` and fill it in. (.env.local is gitignored.)

# REQUIRED — your BrowserCoin wallet address (64 hex chars).
# Copy it from the app: Wallet → Copy. Mining rewards are paid to this address.
MINER_PUBKEY=

# OPTIONAL — where to mine. By default the miner routes to FulgurPool, the
# default pool (https://fulgurpool.xyz). You normally don't touch this.
#   (unset)           → FulgurPool (the default)
#   solo              → always mine on your own
#   https://your.pool → mine at a specific pool
# To add named pools to the launcher's chooser, use pools.json (see
# pools.example.json) instead of editing this line.
# MINER_POOL=

# OPTIONAL — number of CPU worker threads. Default: (CPU cores - 1).
# MINER_WORKERS=4

# OPTIONAL — duty cycle 0.05–1.0: fraction of time spent hashing.
# Lower = cooler/quieter, higher = faster. Default: 0.75.
# MINER_THROTTLE=0.75

# OPTIONAL — comma-separated API helper URLs (used for solo mining / chain sync).
# Default: https://api1.browsercoin.org,https://api2.browsercoin.org
# MINER_HELPERS=https://api1.browsercoin.org,https://api2.browsercoin.org

# OPTIONAL — set to 1 to use the native Rust engine (faster than the default wasm).
# Same as choosing Engine -> native in the menu. If it isn't built yet, the app
# offers to build it on start (cargo build --release) when Rust is installed, and
# otherwise keeps using wasm — it never blocks. Build it by hand any time with:
#   cd native/brc-pow && cargo build --release
# MINER_NATIVE=1

# OPTIONAL — controls TUI mode (the full-screen dashboard). Default: auto-detect
# from the terminal (the dashboard is used when stdout is a TTY).
# Set to 0 to force plain logs even in a terminal.
# FULGUR_TUI=0
